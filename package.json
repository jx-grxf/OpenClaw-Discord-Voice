{
  "name": "OpenClaw-Discord-Voice",
  "version": "1.0.0",
  "description": "Discord voice bridge for OpenClaw with local Whisper STT and macOS TTS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "doctor:bridge": "tsx src/doctor.ts",
    "test": "node --import tsx --test src/*.test.ts src/discord/*.test.ts"
  },
  "keywords": [
    "openclaw",
    "discord",
    "voice",
    "whisper",
    "typescript"
  ],
  "author": "Johannes Grof",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jx-grxf/OpenClaw-Discord-Voice.git"
  },
  "bugs": {
    "url": "https://github.com/jx-grxf/OpenClaw-Discord-Voice/issues"
  },
  "homepage": "https://github.com/jx-grxf/OpenClaw-Discord-Voice#readme",
  "dependencies": {
    "@discordjs/voice": "^0.19.1",
    "@snazzah/davey": "^0.1.9",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
